# ── Wallet ────────────────────────────────────────────────────────────────────
# Kunci privat dompet Solana (format Base58)
WALLET_PRIVATE_KEY=your_solana_private_key_base58

# ── Solana RPC ─────────────────────────────────────────────────────────────────
# URL RPC Solana Anda (misalnya dari Helius, QuickNode, Triton, dll.)
RPC_URL=https://api.mainnet-beta.solana.com

# ── LLM Provider (OpenRouter) ──────────────────────────────────────────────────
# Kunci API OpenRouter untuk memicu DeepSeek V4 Flash
OPENROUTER_API_KEY=your_openrouter_api_key

# Alternatif: Local / LM Studio / Ollama (Uncomment untuk mengaktifkan)
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=your-local-model-name

# ── API Keys Tambahan ──────────────────────────────────────────────────────────
# Diperlukan untuk balance lookups dan token enrichment otonom
HELIUS_API_KEY=your_helius_api_key_optional
GMGN_API_KEY=your_gmgn_api_key_optional

# ── Telegram Bot (Opsional) ────────────────────────────────────────────────────
# Token bot dan ID Chat untuk mengirimkan sinyal & laporan PnL harian ke Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_optional
TELEGRAM_CHAT_ID=your_telegram_chat_id_optional
TELEGRAM_ALLOWED_USER_IDS=your_telegram_chat_id_optional
# TELEGRAM_THREAD_ID=your_telegram_topic_thread_id_optional

# ── Operasional & Keamanan ─────────────────────────────────────────────────────
# DRY_RUN=true: Hanya simulasi (tidak mengirim transaksi on-chain nyata)
# DRY_RUN=false: Mode live trading (menggunakan saldo SOL asli untuk deploy)
DRY_RUN=true
LOG_LEVEL=info
ALLOW_SELF_UPDATE=false
